rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: members
    // Fields:
    //   - name: string (required)
    //   - phone: string
    //   - category: string (enum: Adulto, Jovem, Criança, Visitante)
    //   - active: bool
    //   - createdAt: timestamp
    //
    // Collection: services
    // Fields:
    //   - title: string (required)
    //   - date: string (ISO 8601)
    //   - type: string (enum: Culto de Domingo, Culto de Oração, EBD, Outro)
    //   - description: string
    //
    // Collection: attendance
    // Fields:
    //   - memberId: string (required)
    //   - serviceId: string (required)
    //   - status: string (enum: Presente, Ausente, Justificado)
    //   - date: string (ISO 8601)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "oopgus849@gmail.com" && request.auth.token.email_verified == true
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidMember(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category in ["Adulto", "Jovem", "Criança", "Visitante"] &&
             data.active is bool;
    }

    function isValidService(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.type in ["Culto de Domingo", "Culto de Oração", "EBD", "Outro"] &&
             data.date is string;
    }

    function isValidAttendance(data) {
      return data.memberId is string && data.serviceId is string &&
             data.status in ["Presente", "Ausente", "Justificado"] &&
             data.date is string;
    }

    // Rules
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidMember(request.resource.data);
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidService(request.resource.data);
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidAttendance(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
