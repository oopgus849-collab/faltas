{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "A church member",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "category": { "type": "string", "enum": ["Adulto", "Jovem", "Criança", "Visitante"] },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "active"]
    },
    "Service": {
      "title": "Service",
      "description": "A church service or event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["Culto de Domingo", "Culto de Oração", "EBD", "Outro"] },
        "description": { "type": "string" }
      },
      "required": ["title", "date", "type"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance record for a member at a service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "memberId": { "type": "string" },
        "serviceId": { "type": "string" },
        "status": { "type": "string", "enum": ["Presente", "Ausente", "Justificado"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["memberId", "serviceId", "status", "date"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of church members"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of church services/events"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Collection of attendance records"
    }
  }
}
